TCP_LISTEN_START=8100
TCP_LISTEN_END=8200
TCP_TARGET_HOST=192.168.0.100,127.0.0.1
TCP_TARGET_PORT_OFFSET=1000
TCP_LOG_COALESCE_MS=30

HTTP_LISTEN_PORT=8001
HTTP_TARGET_HOST=192.168.0.100,127.0.0.1  
HTTP_TARGET_PORT_OFFSET=1000
HTTP_BODY_MAX_BYTES=1048576

# MariaDB/MySQL settings
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=proxy
DB_PASSWORD=proxy!@12

# tb_proxy_log 테이블이 있는 MariaDB "database(스키마)" 이름
# 아래 값을 실제 DB명으로 바꿔주세요.
DB_DATABASE="proxy"

# tb_proxy_log.data 저장 방식 (TEXT/LONGTEXT 컬럼이면 base64 권장)
LOG_DATA_ENCODING=hex

